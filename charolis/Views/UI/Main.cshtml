<style>
        /* General Page Styles */
        body {
            font-family: Arial, sans-serif;
            background: #ecf0f1;
            color: #2c3e50;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
            width: 300px;
            text-align: center;
        }

        h2 {
            margin-bottom: 20px;
            color: #34495e;
        }

        ul {
            list-style: none;
            padding: 0;
            margin: 0;
            background: #2c3e50;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.2);
        }

        ul li {
            border-bottom: 1px solid #34495e;
        }

        ul li:last-child {
            border-bottom: none;
        }

        ul li a {
            display: block;
            padding: 15px;
            text-decoration: none;
            color: #ecf0f1;
            font-weight: bold;
            transition: background 0.3s, color 0.3s;
        }

        ul li a:hover {
            background: #1abc9c;
            color: #ffffff;
        }

    </style>
    <div class="container">
        <h2>Charolis</h2>
        <ul>
            <li><a href="@Url.Action("Admins")">Admins</a></li>
            <li><a href="@Url.Action("RegUsers")">RegUsers</a></li>
            <li><a href="@Url.Action("Products")">Products</a></li>
            <li><a href="@Url.Action("Orders")">Orders</a></li>
        </ul>
    </div>