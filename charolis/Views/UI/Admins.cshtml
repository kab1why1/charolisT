<style>
        /* General Page Styling */
        body {
            font-family: Arial, sans-serif;
            background: #ecf0f1;
            color: #2c3e50;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        h2 {
            margin-bottom: 20px;
            color: #34495e;
        }

        /* Table Styling */
        table {
            width: 80%;
            max-width: 900px;
            border-collapse: collapse;
            background: white;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
            border-radius: 8px;
            overflow: hidden;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        th {
            background: #2c3e50;
            color: #ecf0f1;
        }

        tr:hover {
            background: #f1f1f1;
        }

        a {
            text-decoration: none;
            color: #3498db;
            font-weight: bold;
            transition: color 0.3s;
        }

        a:hover {
            color: #1abc9c;
        }

        /* Buttons */
        .button {
            display: inline-block;
            padding: 10px 15px;
            margin: 15px;
            background: #1abc9c;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            transition: background 0.3s;
        }

        .button:hover {
            background: #16a085;
        }
    </style>

    <h2>Список адміністраторів</h2>

    <table>
        <tr>
            <th>Id</th>
            <th>Ім'я</th>
            <th>Email</th>
            <th>Телефон</th>
            <th>Дії</th>
        </tr>
        @foreach (var admin in Model)
        {
            <tr>
                <td>@admin.Id</td>
                <td>@admin.Name</td>
                <td>@admin.Email</td>
                <td>@admin.Phone</td>
                <td>
                    <a href="@Url.Action("EditAdmin", new { id = admin.Id })">Редагувати</a> |
                    <a href="@Url.Action("DeleteAdmin", new { id = admin.Id })" style="color: red;">Видалити</a>
                </td>
            </tr>
        }
    </table>

    <a href="@Url.Action("CreateAdmin")" class="button">Додати адміністратора</a>
    <a href="@Url.Action("Main")" class="button">Назад</a>