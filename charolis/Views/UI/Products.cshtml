@model IEnumerable<charolis.Models.Product>

<style>
        /* General Page Styling */
        body {
            font-family: Arial, sans-serif;
            background: #ecf0f1;
            color: #2c3e50;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h2 {
            color: #34495e;
            margin-bottom: 20px;
        }

        /* Table Styling */
        table {
            width: 90%;
            max-width: 1000px;
            border-collapse: collapse;
            background: white;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
            border-radius: 8px;
            overflow: hidden;
            text-align: left;
        }

        th, td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
        }

        th {
            background: #2c3e50;
            color: #ecf0f1;
            text-align: left;
        }

        tr:nth-child(even) {
            background: #f8f9fa;
        }

        tr:hover {
            background: #f1f1f1;
            transition: background 0.3s;
        }

        /* Action Links */
        a {
            text-decoration: none;
            color: #3498db;
            font-weight: bold;
            transition: color 0.3s;
        }

        a:hover {
            color: #1abc9c;
        }

        a[style*="color: red;"] {
            color: red;
        }

        a[style*="color: red;"]:hover {
            color: darkred;
        }

        /* Buttons */
        .button {
            display: inline-block;
            padding: 12px 20px;
            margin: 15px;
            background: #1abc9c;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            transition: background 0.3s;
        }

        .button:hover {
            background: #16a085;
        }
    </style>
    <h2>Список продуктів</h2>

    <table>
        <tr>
            <th>Id</th>
            <th>Ім'я</th>
            <th>Опис</th>
            <th>Ціна</th>
            <th>Наявність</th>
            <th>Дії</th>
        </tr>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Desc</td>
                <td>@product.Price ₴</td>
                <td>@(product.Awailible ? "✅ Є в наявності" : "❌ Немає")</td>
                <td>
                    <a href="@Url.Action("EditProduct", new { id = product.Id })">Редагувати</a> |
                    <a href="@Url.Action("DeleteProduct", new { id = product.Id })" style="color: red;">Видалити</a>
                </td>
            </tr>
        }
    </table>

    <a href="@Url.Action("CreateProduct")" class="button">Додати продукт</a>
    <a href="@Url.Action("Main")" class="button">⬅ Назад</a>